[62.712553, "i", "python3 -c \"\nimport struct\nimport numpy as np\n\n# TensorFlow checkpoint format - let's try to read it\n# The newer TF checkpoint format uses a header with magic number\n\nwith open('/app/gpt2-124M.ckpt', 'rb') as f:\n    # Read first few bytes\n    magic = f.read(8)\n    print(f'Magic bytes: {magic.hex()}')\n    \n    # Try to read as TFRecord format\n    f.seek(0)\n    data = f.read(1000)\n    print(f'First 1000 bytes (hex): {data[:100].hex()}')\n\"\n"]
