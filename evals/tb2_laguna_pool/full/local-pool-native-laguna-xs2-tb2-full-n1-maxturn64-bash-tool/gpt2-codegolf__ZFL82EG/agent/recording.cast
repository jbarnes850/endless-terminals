[458.55769, "i", "python3 -c \"\n# Try to read checkpoint using standard library\nimport struct\n\nwith open('/app/gpt2-124M.ckpt', 'rb') as f:\n    # Read the entire file\n    data = f.read()\n    print(f'File size: {len(data)} bytes')\n    \n    # Try to find strings in the file\n    text = data.decode('latin-1')\n    \n    # Find patterns like 'kernel', 'bias', 'embed', 'layer', 'norm', 'weight'\n    patterns = ['kernel', 'bias', 'embed', 'layer', 'norm', 'weight']\n    for p in patterns:\n        if p in text:\n            idx = text.find(p)\n            print(f'Found {p} at position {idx}')\n            print(f'Context: {text[max(0,idx-20):idx+50]}')\n\"\n"]
