[24.351431, "i", "python3 << 'EOF'\nimport struct\n\n# Read the checkpoint file header\nwith open('/app/gpt2-124M.ckpt', 'rb') as f:\n    # Try to read as TF checkpoint\n    data = f.read(100)\n    print(\"First 100 bytes (hex):\", data.hex())\n    \n# Check if it's a TensorFlow checkpoint\n# TF checkpoints start with a magic number or have specific format\n# Let's try to read the whole file and look for patterns\nwith open('/app/gpt2-124M.ckpt', 'rb') as f:\n    content = f.read()\n    print(f\"\\nFile size: {len(content)}\")\n    # Look for common TF checkpoint markers\n    if b'magic' in content[:1000]:\n        print(\"Found 'magic' in header\")\n    else:\n        print(\"No 'magic' found in first 1000 bytes\")\nEOF\n"]
